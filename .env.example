# Example env file. Copy to .env.local for local dev and configure
# in Vercel dashboard for production deploys.
#
# Public Supabase config (anon key — safe to ship to client).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Smartsupp live-chat widget key (PUBLIC, not the secret API key).
# Get this from Smartsupp dashboard → Settings → Channels → Chat widget.
VITE_SMARTSUPP_WIDGET_KEY=
VITE_SMARTSUPP_LABEL=OrbitPay Support

# Optional: build-time SHA injected into the footer.
VITE_BUILD_SHA=dev

# Optional: API base URL for the admin/portal REST layer.
VITE_API_URL=/api